#include <stdio.h>
int main (){
    int n,i;
    int first = 0, second = 1, next;
    printf("Enter the value of n:\n");
    scanf("%d", &n);
    printf ("The Fibonacci sequence up to %d terms is :\n", n);
    for(i=1; i<=n; i++){
        printf ("%d\t", first);
        next = first + second;
        first = second;
        second = next;
    }
    return 0;
    }

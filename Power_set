#include <stdio.h>
int power (int x, int y){
    if (y==0)
    return 1;
    else 
    return x*power (x, y-1);
}
int main (){
    int x,y;
    printf ("Enter base (x) :");
    scanf ("%d", &x);
    printf ("Enter exp (y) :");
    scanf ("%d", &y);
    printf ("%d raised to a power %d is = %d\n", x,y, power (x,y));
    return 0;
}
